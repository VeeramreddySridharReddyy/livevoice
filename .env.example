# ================= LiveVoice configuration =================
#
# BYOK model: each SPEAKER pastes their own Deepgram API key in the browser
# when they start a session. The deployed server needs NO key at all.
#
# Everything below is OPTIONAL — a local-dev convenience so *you* aren't
# prompted for a key on your own machine.

# Which speech-to-text provider to use: "deepgram" or "assemblyai"
STT_PROVIDER=deepgram

# Optional local-dev fallback key (skips the in-browser key prompt).
# Get one free: https://console.deepgram.com/  ->  API Keys  ->  Create a Key
#DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Model + language for transcription
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-IN

# Only relevant if STT_PROVIDER=assemblyai
#ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ---- Server ----
# Most hosts (Render/Railway/Fly) set PORT automatically.
PORT=3000
